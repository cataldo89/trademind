# .env.example - Copia este archivo como .env.local y completa valores reales
# NUNCA subas .env.local ni .env.production a GitHub
# No uses placeholders con forma de JWT, PAT ni connection strings reales.

# ================================
# SUPABASE - APP NEXT/VERCEL
# ================================
NEXT_PUBLIC_SUPABASE_URL=https://replace-with-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ================================
# SUPABASE - CLI/SCRIPTS
# ================================
SUPABASE_PROJECT_REF=replace-with-project-ref
SUPABASE_ACCESS_TOKEN=replace-with-supabase-access-token
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
DATABASE_URL=replace-with-postgres-connection-string

# ================================
# AI / LLM APIs
# ================================
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# ================================
# MARKET DATA APIs
# ================================
ALPHA_VANTAGE_API_KEY=replace-with-alpha-vantage-api-key
FINNHUB_API_KEY=replace-with-finnhub-api-key
POLYGON_API_KEY=replace-with-polygon-api-key

# ================================
# QUANT ENGINE - NEXT -> FASTAPI
# ================================
QUANT_ENGINE_URL=http://127.0.0.1:8000
QUANT_ENGINE_SECRET=replace-with-quant-engine-secret
QUANT_ENGINE_AUTH_DISABLED=true

# ================================
# QUANTCONNECT / LEAN
# ================================
QC_USER_ID=replace-with-quantconnect-user-id
QC_API_TOKEN=replace-with-quantconnect-api-token

# ================================
# SCRIPTS DE UTILIDAD
# ================================
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=replace-with-local-test-password

