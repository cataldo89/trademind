# TradeMind Quant Engine Environment Variables
QC_API_TOKEN=your_quantconnect_api_token_here
QC_USER_ID=your_quantconnect_user_id_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FINNHUB_API_KEY=your_finnhub_key_here
NEWSAPI_KEY=your_newsapi_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Sentiment news collection
SENTIMENT_NEWS_SOURCES=google,gdelt,yahoo,finnhub,newsapi,sec,presswire,macro
SENTIMENT_SCAN_MAX_SYMBOLS=30
SENTIMENT_MAX_HEADLINES=25
SENTIMENT_LOOKBACK_DAYS=14
SENTIMENT_SOURCE_TIMEOUT_SECONDS=6
SENTIMENT_SOURCE_CONCURRENCY=6
SENTIMENT_INCLUDE_MACRO_NEWS=false
SENTIMENT_USER_AGENT=TradeMindQuantEngine/1.0
# Required to activate SEC EDGAR. Use a real contact email.
SEC_USER_AGENT=TradeMindQuantEngine/1.0 your-email@example.com
# Optional: comma-separated "Name=https://feed.example/rss.xml" entries.
SENTIMENT_EXTRA_RSS_FEEDS=

# Security Settings
QUANT_ENGINE_SECRET=your_secret_key_here
QUANT_ENGINE_AUTH_DISABLED=false
QUANT_ENGINE_ALLOWED_ORIGINS=http://localhost:3000,https://trademind-cv-ten.vercel.app

