# TradeMind Quant Engine Environment Variables
QC_API_TOKEN=your_quantconnect_api_token_here
QC_USER_ID=your_quantconnect_user_id_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Security Settings
QUANT_ENGINE_SECRET=your_secret_key_here
QUANT_ENGINE_AUTH_DISABLED=false
QUANT_ENGINE_ALLOWED_ORIGINS=http://localhost:3000,https://trademind-cv.vercel.app

